{
  "name": "hyperion-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "architecture:check": "node tools/boundary-check.mjs",
    "check": "pnpm run format:check && pnpm run lint && pnpm run db:format && pnpm run db:validate && pnpm run db:generate && pnpm run typecheck && pnpm run test && pnpm run secret:scan && pnpm run architecture:check && pnpm run db:schema:check && pnpm run repo:guard",
    "db:format": "node tools/prisma-cli.mjs format --schema packages/db/prisma/schema.prisma",
    "db:validate": "node tools/prisma-cli.mjs validate --schema packages/db/prisma/schema.prisma",
    "db:generate": "node tools/prisma-cli.mjs generate --schema packages/db/prisma/schema.prisma",
    "db:migration:check": "node tools/db-schema-check.mjs",
    "db:migrate:test": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:reset:test": "node -e \"console.log('DB integration cleanup is handled by packages/db/src/integration/prisma-test-harness.ts.');\"",
    "db:schema:check": "node tools/db-schema-check.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "node -e \"console.log('No integration tests yet.');\"",
    "test:integration:api": "vitest run apps/api/src/integration --maxWorkers=1",
    "test:integration:db": "vitest run packages/db/src/integration/prisma-integration.test.ts",
    "repo:guard": "node tools/repo-guard.mjs",
    "secret:scan": "node tools/secret-scan.mjs",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  }
}
